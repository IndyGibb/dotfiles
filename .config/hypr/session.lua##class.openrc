return function(hl)
  hl.on("hyprland.start", function()
    -- no systemd target on OpenRC - start what the target used to pull in, directly (dbus session already exists via dbus-run-session):
    hl.exec_cmd("/usr/libexec/xdg-desktop-portal-hyprland")
    hl.exec_cmd("gentoo-pipewire-launcher")
  end)
end

